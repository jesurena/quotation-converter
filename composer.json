{
    "name": "quotation/converter",
    "version": "1.0.0",
    "description": "A standalone, version-agnostic Laravel package for generating quotation PDFs. Pure Data-to-PDF engine with no SQL dependencies.",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "ICS Development Team"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "dompdf/dompdf": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Quotation\\Converter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Quotation\\Converter\\Providers\\QuotationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
